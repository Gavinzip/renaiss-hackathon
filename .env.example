# Public origin and server
PUBLIC_APP_ORIGIN=http://localhost:4173
PORT=4174
DATABASE_PATH=./data/renaiss-hackathon.sqlite

# Required for production builds after publishing the immutable R2 release.
# Use the active public R2 origin, for example https://pub-<bucket-id>.r2.dev.
# An attached custom domain is optional and may be used instead when needed.
VITE_STATIC_ASSET_CDN_BASE_URL=
# Google Analytics 4 public Measurement ID. Set this only in the Zeabur build
# environment after the GA web stream has been created (for example G-XXXXXXXXXX).
VITE_GA_MEASUREMENT_ID=
AUTH_SESSION_SECRET=

# Renaiss production OIDC. The client secret must remain server-side.
RENAISS_ISSUER=https://www.renaiss.xyz/api/auth
RENAISS_CLIENT_ID=
RENAISS_CLIENT_SECRET=
RENAISS_REDIRECT_URI=
RENAISS_SCOPE=openid profile email safe x
RENAISS_TOKEN_AUTH_METHOD=post

# Private organizer dashboard. Only the verified Renaiss Safe wallet addresses listed here can read live vote totals.
ADMIN_SAFE_WALLET_ADDRESSES=

# Server-side SBT eligibility gate. A verified Safe wallet must hold at least
# Minimum number of distinct positive ERC-1155 Renaiss SBT token IDs required to vote.
# Obtain the official Renaiss SBT contract from the organizer configuration; keep the API key server-only.
BSCSCAN_API_URL=https://api.etherscan.io/v2/api
BSCSCAN_CHAIN_ID=56
BSCSCAN_API_KEY=
ONCHAIN_SBT_CONTRACT=
VOTE_MINIMUM_SBT_BADGES=10
VOTE_SBT_CACHE_TTL_SECONDS=60
BSCSCAN_TIMEOUT_MS=8000
# Protect the shared BscScan API quota during a vote rush. Use the limit for
# the deployed API plan; duplicate checks for the same wallet are coalesced.
BSCSCAN_REQUESTS_PER_SECOND=3
BSCSCAN_MAX_CONCURRENT_REQUESTS=3
BSCSCAN_MAX_QUEUED_REQUESTS=360

# One account is still bounded tightly, while a shared school or office IP can
# submit a normal vote rush without falsely blocking legitimate voters.
VOTE_RATE_LIMIT=12
VOTE_RATE_WINDOW_SECONDS=60
VOTE_IP_RATE_LIMIT=360
VOTE_IP_RATE_WINDOW_SECONDS=60

# Official organizer settings. Set the opening time before launch. The Season 1
# source policy closes at 2026-07-20T23:59:59+08:00. If you explicitly set
# VOTING_CLOSES_AT here or in Zeabur, keep it aligned with that official value.
VOTING_OPENS_AT=
VOTING_CLOSES_AT=
RESULTS_PUBLISHED=false

# Optional offsite SQLite snapshots. Set all three together in Zeabur Variables.
# This remote uses a dedicated Google OAuth client with access limited to files it creates.
BACKUP_REPOSITORY=rclone:gdrive:restic
RESTIC_PASSWORD=
BACKUP_TRIGGER_SECRET=
BACKUP_STAGING_DIR=/data/backup-staging
BACKUP_TIMEOUT_SECONDS=1800
BACKUP_KEEP_HOURLY=48
BACKUP_KEEP_DAILY=14
BACKUP_KEEP_WEEKLY=8
BACKUP_KEEP_MONTHLY=12
RCLONE_CONFIG_GDRIVE_TYPE=drive
RCLONE_CONFIG_GDRIVE_SCOPE=drive.file
RCLONE_CONFIG_GDRIVE_ROOT_FOLDER_ID=
RCLONE_CONFIG_GDRIVE_CLIENT_ID=
RCLONE_CONFIG_GDRIVE_CLIENT_SECRET=
RCLONE_CONFIG_GDRIVE_TOKEN=
